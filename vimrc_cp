" プラグイン管理
call plug#begin('~/.vim/plugged')
Plug 'EdenEast/nightfox.nvim'
call plug#end()

" 機能の初期設定
set nocompatible
syntax on
set t_Co=256
set mouse=

" カラースキーム設定
colorscheme nightfox
" 背景透過設定（カラースキームの後に書く！）
highlight Normal ctermbg=NONE guibg=NONE
highlight NonText ctermbg=NONE guibg=NONE
highlight LineNr ctermbg=NONE guibg=NONE
highlight SignColumn ctermbg=NONE guibg=NONE
highlight EndOfBuffer ctermbg=NONE guibg=NONE
" 表示の設定
set number
set wildmenu
set showcmd

" キーバインド
autocmd FileType html,markdown nnoremap <buffer> <CR> a<br><CR><Esc>
highlight Comment ctermfg=lightblue

" インデント関連の設定
set tabstop=4
set autoindent
set nosmartindent
set nocindent
set expandtab

" macのクリップボード関連の設定
set clipboard=unnamed
set clipboard+=unnamedplus

" 検索機能
set ignorecase
set hlsearch
nnoremap <Esc> :noh<CR>

"独自コマンド
":Memoでメモファイルを開く
command! Memo execute 'edit ~/Desktop/memo/' . 'memo.md'
":Dmemoで日毎に別れたメモを開く
command! Dmemo execute 'edit ~/Desktop/memo/' . strftime('%Y-%m-%d') . '.md'
":Pmemoでpythonファイルを開く
command! Pmemo execute 'edit ~/Desktop/memo/' . 'test.py'
":Pyでpythonファイルを走らせる
command! Py %w !python3
":Wや:Wqでも保存ができるように(ミスが多いため)
command! W w
command! Wq wq
":Asでswiftのプログラムを走らせる(atcoder用)
command! As w|!swift < test.txt
":Apでpythonのプログラムを走らせる(atcoder用)
command! Ap w|!python3 < test.txt
":Cでファイルをコピーする
command! C silent %w !pbcopy
