# focus
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# swap
alt + shift - h : yabai -m window --swap west
alt + shift - j : yabai -m window --swap south
alt + shift - k : yabai -m window --swap north
alt + shift - l : yabai -m window --swap east

# warp
cmd + alt - h : yabai -m window --warp west
cmd + alt - j : yabai -m window --warp south
cmd + alt - k : yabai -m window --warp north
cmd + alt - l : yabai -m window --warp east
# float
alt - t : yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2

# zoom
alt - f : yabai -m window --toggle zoom-fullscreen

# rebalance
alt - b : yabai -m space --balance
# option+enterで画面の最大化

alt - return : yabai -m window --toggle zoom-fullscreen

# 比率の変更

ctrl + alt - h : yabai -m window --resize left:-80:0

ctrl + alt - l : yabai -m window --resize right:80:0



ctrl + alt - k : yabai -m window --resize top:0:-80

ctrl + alt - j : yabai -m window --resize bottom:0:80



# スペースを3つぐらい作る

alt - 1 : yabai -m space --focus 1

alt - 2 : yabai -m space --focus 2

alt - 3 : yabai -m space --focus 3

# ショートカットでArc cmux discordを開けるように
alt - a : open -a "Arc"
alt - c : open -a "cmux"
alt - d : open -a "Discord"
